# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zcw_blog
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/zcw_blog

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# LLM (optional, for RAG)
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# Embedding model
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

# Logging
LOG_LEVEL=DEBUG

# Rate limit
RATE_LIMIT_PER_MINUTE=60
